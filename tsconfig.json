{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["bin/**/*.ts", "remotion.config.ts", "src/**/*.ts", "remotion/**/*.ts", "remotion/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
